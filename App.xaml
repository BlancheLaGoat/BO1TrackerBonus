<Application x:Class="BO1Tracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ============================================================
             COULEURS
        ============================================================ -->
        <SolidColorBrush x:Key="BrushBgMain"        Color="#111213" />
        <SolidColorBrush x:Key="BrushBgCard"        Color="#1A1B1E" />
        <SolidColorBrush x:Key="BrushBgHistory"     Color="#161719" />
        <SolidColorBrush x:Key="BrushBorder"        Color="#2E3035" />
        <SolidColorBrush x:Key="BrushBorderHover"   Color="#50545E" />
        <SolidColorBrush x:Key="BrushAccent"        Color="#1D9E75" />
        <SolidColorBrush x:Key="BrushAccentDark"    Color="#0D3326" />
        <SolidColorBrush x:Key="BrushAccentLight"   Color="#4ECDA4" />
        <SolidColorBrush x:Key="BrushTextPrimary"   Color="#E8EAF0" />
        <SolidColorBrush x:Key="BrushTextSecondary" Color="#8B8FA8" />
        <SolidColorBrush x:Key="BrushTextMuted"     Color="#50545E" />
        <SolidColorBrush x:Key="BrushSeparator"     Color="#252830" />
        <SolidColorBrush x:Key="BrushDisabled"      Color="#2A1A1A" />
        <SolidColorBrush x:Key="BrushDisabledBorder" Color="#6B2A2A" />
        <SolidColorBrush x:Key="BrushDisabledText"  Color="#B05050" />

        <!-- ============================================================
             STYLE : BOUTON MAP
        ============================================================ -->
        <Style x:Key="MapButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="#1A1B1E" />
            <Setter Property="Foreground"      Value="#8B8FA8" />
            <Setter Property="BorderBrush"     Value="#2E3035" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="14,6" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="#212328" />
                                <Setter TargetName="border" Property="BorderBrush"  Value="#50545E" />
                                <Setter Property="Foreground" Value="#E8EAF0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#0D3326" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1D9E75" />
                                <Setter Property="Foreground" Value="#4ECDA4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             STYLE : BOUTON ACTIVER/DÉSACTIVER UN BONUS
             Vert quand activé, rouge quand désactivé
        ============================================================ -->
        <Style x:Key="ToggleDropButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="#0D3326" />
            <Setter Property="Foreground"      Value="#4ECDA4" />
            <Setter Property="BorderBrush"     Value="#1D9E75" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="14,6" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="dot" Text="● " FontSize="10"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Désactivé = rouge -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="border" Property="Background"  Value="#2A1A1A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#6B2A2A" />
                                <Setter Property="Foreground" Value="#B05050" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#50545E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================
             STYLE : BOUTON RESET (neutre gris)
        ============================================================ -->
        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1A1B1E" />
            <Setter Property="Foreground"      Value="#8B8FA8" />
            <Setter Property="BorderBrush"     Value="#50545E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="18,7" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#212328" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B8FA8" />
                                <Setter Property="Foreground" Value="#E8EAF0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Variante rouge pour "Réinitialiser l'historique" -->
        <Style x:Key="ResetDangerButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ResetButtonStyle}">
            <Setter Property="BorderBrush" Value="#6B2A2A" />
            <Setter Property="Foreground"  Value="#B05050" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#2A1A1A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#B05050" />
                                <Setter Property="Foreground" Value="#E05050" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
