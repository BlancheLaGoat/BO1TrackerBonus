<Window x:Class="BO1Tracker.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BO1 Overlay"
        Width="560" Height="160"
        MinWidth="200" MinHeight="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Closing="OverlayWindow_Closing">

    <Window.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background"      Value="#22FFFFFF"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModeBtn" TargetType="Button">
            <Setter Property="Background"      Value="#33FFFFFF"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="9"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
        <StackPanel>

            <!-- Barre de contrôle (toujours visible) -->
            <Border Background="#DD111111" CornerRadius="8,8,0,0" Padding="10,6">
                <DockPanel>
                    <!-- Sélecteur de mode -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ModeBO1Btn" Content="BO1 BONUS" Style="{StaticResource ModeBtn}" Margin="0,0,4,0" Click="ModeBO1_Click"/>
                        <Button x:Name="ModeBO2Btn" Content="BO2 BONUS" Style="{StaticResource ModeBtn}" Margin="0,0,4,0" Click="ModeBO2_Click"/>
                        <Button x:Name="ModeBoxBtn" Content="BOÎTE"     Style="{StaticResource ModeBtn}" Click="ModeBox_Click"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="TopBtn"  Content="FOND"   Style="{StaticResource CtrlBtn}" Margin="0,0,4,0" Click="TopButton_Click"/>
                        <Button x:Name="LockBtn" Content="LOCK"   Style="{StaticResource CtrlBtn}" Margin="0,0,4,0" Click="LockButton_Click"/>
                        <Button                  Content="✕"      Style="{StaticResource CtrlBtn}" Foreground="#FF6B6B" Click="CloseButton_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Contenu -->
            <Border Background="#CC111111" CornerRadius="0,0,8,8" Padding="12,10">
                <StackPanel>
                    <WrapPanel x:Name="CardsPanel" Orientation="Horizontal"/>
                    <TextBlock x:Name="EmptyText"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#444444" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>
